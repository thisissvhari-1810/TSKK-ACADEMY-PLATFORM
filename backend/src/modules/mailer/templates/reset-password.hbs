<!-- subject: Reset your TSKK Academy password -->
{{#> _layout title="Reset your password"}}
  <h2 style="margin:0 0 16px;color:#111827;font-size:22px;">Password reset requested</h2>
  <p style="margin:0 0 12px;">Hi {{firstName}}, we received a request to reset the password for your account associated with <strong>{{email}}</strong>.</p>
  <p style="text-align:center;margin:28px 0;">
    <a href="{{resetUrl}}" style="display:inline-block;background:#B91C1C;color:#ffffff;text-decoration:none;padding:14px 28px;border-radius:8px;font-weight:600;">Set a New Password</a>
  </p>
  <p style="margin:0 0 8px;color:#6b7280;font-size:13px;">Or copy and paste this link into your browser:</p>
  <p style="margin:0 0 16px;word-break:break-all;color:#374151;font-size:13px;"><a href="{{resetUrl}}" style="color:#B91C1C;">{{resetUrl}}</a></p>
  <p style="margin:24px 0 0;color:#6b7280;font-size:13px;">This link will expire in <strong>{{expiresInMinutes}} minutes</strong>. If you did not request this reset, you can safely ignore this email — your password will not be changed.</p>
  {{#if requestIp}}
  <p style="margin:12px 0 0;color:#9ca3af;font-size:12px;">Request originated from IP {{requestIp}}.</p>
  {{/if}}
{{/_layout}}
