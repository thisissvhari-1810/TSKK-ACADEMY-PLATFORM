<!-- subject: Your TSKK Academy password was changed -->
{{#> _layout title="Password changed"}}
  <h2 style="margin:0 0 16px;color:#111827;font-size:22px;">Your password was changed</h2>
  <p style="margin:0 0 12px;">Hi {{firstName}}, we're writing to confirm that the password for your account <strong>{{email}}</strong> was changed on {{changedAt}}.</p>
  <p style="margin:0 0 12px;">All previous sessions have been signed out for your security.</p>
  <p style="margin:20px 0 0;color:#374151;">If you did not perform this action, please contact our support team immediately.</p>
{{/_layout}}
