<!-- subject: Welcome to TSKK Academy -->
{{#> _layout title="Welcome to TSKK Academy"}}
  <h2 style="margin:0 0 16px;color:#111827;font-size:22px;">Welcome aboard, {{firstName}}!</h2>
  <p style="margin:0 0 12px;">Your account with <strong>{{academyName}}</strong> is now active. You can log in and start using the platform right away.</p>
  <p style="text-align:center;margin:28px 0;">
    <a href="{{loginUrl}}" style="display:inline-block;background:#B91C1C;color:#ffffff;text-decoration:none;padding:14px 28px;border-radius:8px;font-weight:600;">Go to Dashboard</a>
  </p>
  <p style="margin:0 0 12px;color:#374151;">Your registered role: <strong>{{role}}</strong></p>
  <p style="margin:12px 0 0;color:#6b7280;font-size:13px;">If you have questions, reply to this email and our team will get back to you.</p>
{{/_layout}}
