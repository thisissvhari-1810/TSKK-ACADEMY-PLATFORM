<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8" />
<title>Receipt {{receiptNumber}}</title>
<style>
  @page { size: A4; margin: 18mm 15mm; }
  body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif; color: #111827; font-size: 12px; margin: 0; }
  header { display: flex; justify-content: space-between; align-items: center; border-bottom: 3px solid {{primaryColor}}; padding-bottom: 12px; margin-bottom: 20px; }
  header h1 { margin: 0; font-size: 22px; color: {{primaryColor}}; }
  header p { margin: 2px 0 0; color: #6b7280; font-size: 11px; }
  .meta { text-align: right; }
  .meta .label { color: #6b7280; text-transform: uppercase; font-size: 10px; letter-spacing: .5px; }
  .meta .value { font-size: 14px; font-weight: 700; color: #111827; }
  .status-paid { display: inline-block; padding: 4px 12px; background: #dcfce7; color: #166534; border-radius: 999px; font-weight: 700; font-size: 11px; letter-spacing: .5px; margin-top: 4px; }
  section { margin-bottom: 22px; }
  section h2 { margin: 0 0 8px; font-size: 12px; text-transform: uppercase; letter-spacing: .5px; color: #6b7280; }
  .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .card { border: 1px solid #e5e7eb; border-radius: 8px; padding: 12px 14px; }
  .card strong { display: block; margin-bottom: 4px; color: #111827; }
  table { width: 100%; border-collapse: collapse; margin-top: 6px; }
  th, td { padding: 8px 10px; text-align: left; border-bottom: 1px solid #e5e7eb; }
  th { background: #f9fafb; font-weight: 600; font-size: 11px; text-transform: uppercase; letter-spacing: .5px; color: #6b7280; }
  .total-row td { font-weight: 700; background: {{primaryColor}}; color: #fff; }
  footer { position: fixed; bottom: 10mm; left: 15mm; right: 15mm; text-align: center; color: #9ca3af; font-size: 10px; border-top: 1px solid #e5e7eb; padding-top: 6px; }
</style>
</head>
<body>
<header>
  <div>
    <h1>{{academy.name}}</h1>
    <p>{{academy.address}}</p>
    <p>{{academy.contactPhone}} · {{academy.contactEmail}}</p>
    {{#if academy.taxNumber}}<p>Tax No: {{academy.taxNumber}}</p>{{/if}}
  </div>
  <div class="meta">
    <div class="label">Receipt</div>
    <div class="value">{{receiptNumber}}</div>
    <div class="status-paid">PAID</div>
  </div>
</header>

<section class="grid">
  <div class="card">
    <strong>Student</strong>
    <div>{{student.firstName}} {{student.lastName}}</div>
    <div style="color:#6b7280;font-size:11px;">Code: {{student.studentCode}}</div>
    {{#if student.guardianName}}<div style="color:#6b7280;font-size:11px;">Guardian: {{student.guardianName}}</div>{{/if}}
  </div>
  <div class="card">
    <strong>Payment details</strong>
    <div>Paid on: {{paidAt}}</div>
    <div>Method: {{method}}</div>
    {{#if gatewayPaymentId}}<div style="color:#6b7280;font-size:11px;">Ref: {{gatewayPaymentId}}</div>{{/if}}
  </div>
</section>

{{#if invoice}}
<section>
  <h2>Invoice</h2>
  <table>
    <thead>
      <tr><th>Invoice #</th><th>Type</th><th>Due date</th><th style="text-align:right;">Total</th><th style="text-align:right;">Balance</th></tr>
    </thead>
    <tbody>
      <tr>
        <td>{{invoice.number}}</td>
        <td>{{invoice.type}}</td>
        <td>{{invoice.dueDate}}</td>
        <td style="text-align:right;">{{invoice.totalFormatted}}</td>
        <td style="text-align:right;">{{invoice.balanceFormatted}}</td>
      </tr>
    </tbody>
  </table>
</section>
{{/if}}

<section>
  <h2>Amount received</h2>
  <table>
    <tbody>
      <tr class="total-row">
        <td>Total paid ({{method}})</td>
        <td style="text-align:right;">{{amountFormatted}}</td>
      </tr>
    </tbody>
  </table>
</section>

<footer>
  This is a computer-generated receipt. © {{year}} {{academy.name}}.
</footer>
</body>
</html>
