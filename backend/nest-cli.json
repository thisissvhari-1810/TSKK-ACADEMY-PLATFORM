{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "builder": "swc",
    "typeCheck": false,
    "deleteOutDir": true,
    "assets": [
      { "include": "modules/**/templates/**/*", "outDir": "dist" },
      { "include": "modules/**/assets/**/*", "outDir": "dist" }
    ],
    "watchAssets": true
  }
}
